{
  "version": "control_v46_caption_prompt_predictive_validity",
  "locked_on": "2026-05-27",
  "purpose": "Test whether predictive validity survives a second held-out caption-like prompt template, after the photo prompt exposed bedroom sensitivity.",
  "experiments": [
    {
      "key": "church_control_v46_caption_prompt_predictive_validity_seed_2062",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "Predictive-validity assumption stress test: curvature/risk should predict identity/perceptual damage after semantic gain is controlled in church, with risk_estimator=jvp and prompt_style=caption.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "min-gain-quantile": 0.5,
        "gain-match-rel": 0.25,
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "risk-estimator": "jvp",
        "prompt-style": "caption",
        "out": "experiments/out/control_cross_domain_risk_predictive_prompt_caption/church_seed_2062",
