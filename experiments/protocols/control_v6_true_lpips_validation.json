{
  "version": "control_v6_true_lpips_validation",
  "locked_on": "2026-05-24",
  "purpose": "Validate the control claim with real LPIPS, not only the downsampled-L2 perceptual proxy used by the faster controller sweeps.",
  "common": {
    "lod": 2.0,
    "batch": 4,
    "device": "cuda",
    "domain": "ffhq",
    "attrs": ["smile", "age", "pose", "gender", "eyeglasses"],
    "candidate_source": "experiments/out/control_direction_matched_full/metrics.json",
    "lpips_net": "alex"
  },
  "experiments": [
    {
      "key": "true_lpips_seed_2027",
      "order": 1,
      "script": "experiments/control/run_risk_aware_controller.py",
      "claim_tested": "Real-LPIPS validation: risk-aware controller should preserve lower perceptual drift than gain-only/random/high-risk under the same split protocol.",
      "args": {
        "candidate-source": "experiments/out/control_direction_matched_full/metrics.json",
        "k-select": 8,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "actual",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-probe": 32,
        "probe-alpha": 1.0,
        "n-calib": 32,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "lod": 2,
        "out": "experiments/out/control_true_lpips_validation/seed_2027",
        "seed": 2027
