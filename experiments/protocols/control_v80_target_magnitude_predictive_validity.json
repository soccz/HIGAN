      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "Top-tier defense: rho predictive validity should remain auditable under target_q10 in church; failures are kept as boundary evidence.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
