{
  "version": "control_v57_prompt_ensemble_fd_predictive_validity",
  "locked_on": "2026-05-28",
  "purpose": "Test whether prompt-ensemble predictive validity survives replacing JVP rho with finite-difference rho.",
  "experiments": [
    {
      "key": "church_control_v57_prompt_ensemble_fd_predictive_validity_seed_2092",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "Prompt-ensemble predictive validity should remain directionally stable under this stress setting in church.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "min-gain-quantile": 0.5,
        "gain-match-rel": 0.25,
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "risk-estimator": "fd",
        "prompt-style": "ensemble",
        "out": "experiments/out/control_cross_domain_risk_predictive_prompt_ensemble_fd/church_seed_2092",
        "seed": 2092,
        "fd-eps": 0.25
