{
  "version": "control_v5_risk_power_sensitivity",
  "locked_on": "2026-05-24",
  "purpose": "Sensitivity validation for the predeclared gain/risk controller. The official controller uses risk_power=1.0; this protocol checks whether the paper claim is robust around that value rather than dependent on a single exponent.",
  "common": {
    "lod": 2.0,
    "batch": 4,
    "device": "cuda",
    "domain": "ffhq",
    "attrs": ["smile", "age", "pose", "gender", "eyeglasses"],
    "candidate_source": "experiments/out/control_direction_matched_full/metrics.json"
  },
  "experiments": [
    {
      "key": "risk_power_0p5_seed_2027",
      "order": 1,
      "script": "experiments/control/run_risk_aware_controller.py",
      "claim_tested": "Sensitivity check: weaker risk penalty should still be reported against all baselines.",
      "args": {
        "candidate-source": "experiments/out/control_direction_matched_full/metrics.json",
        "k-select": 8,
        "min-gain-quantile": 0.5,
        "risk-power": 0.5,
        "risk-selection-mode": "actual",
        "n-probe": 32,
        "probe-alpha": 1.0,
        "n-calib": 32,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "lod": 2,
        "out": "experiments/out/control_risk_power_sensitivity/risk_power_0p5_seed_2027",
        "seed": 2027
      }
    },
