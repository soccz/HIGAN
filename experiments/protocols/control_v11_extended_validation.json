{
  "version": "control_v11_extended_validation",
  "locked_on": "2026-05-24",
  "purpose": "Extended main-paper validation of the control claim: real LPIPS under fixed targets, sample-budget sensitivity, k sensitivity, gain-threshold sensitivity, and target-magnitude sensitivity.",
