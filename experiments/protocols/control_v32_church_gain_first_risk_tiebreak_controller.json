{
  "version": "control_v32_church_gain_first_risk_tiebreak_controller",
  "locked_on": "2026-05-27",
  "purpose": "Held-out controller test that uses risk as a tiebreaker inside a high-gain candidate pool, instead of relying on the original gain/risk ratio.",
  "experiments": [
    {
      "key": "church_gain_first_risk_tiebreak_actual_seed_2042",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Held-out gain-first/risk-tiebreak controller: risk should act as a control signal inside a high-gain candidate pool.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "selection-rule": "gain_topk_low_risk",
        "gain-pool-multiplier": 2.0,
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_church_gain_first_risk_tiebreak/actual_seed_2042",
