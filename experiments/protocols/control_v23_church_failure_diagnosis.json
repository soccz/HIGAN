{
  "version": "control_v23_church_failure_diagnosis",
  "locked_on": "2026-05-26",
  "purpose": "Diagnose the church StyleGAN2 weakness observed against random/low-risk baselines. This protocol tests whether the weakness is caused by including unstructured random directions in the candidate universe, or by allowing too-low semantic-gain candidates into the risk-aware selection pool.",
  "common": {
    "domain": "church",
    "attrs": ["clouds", "sunny", "vegetation"],
    "target_source": "universe",
    "lpips_net": "alex"
  },
  "experiments": [
    {
      "key": "church_structured_only_seed_2027",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Failure diagnosis: restrict the church candidate universe to structured directions only (GANSpace+SeFa), keeping the controller rule fixed.",
      "args": {
        "domain": "church",
        "attrs": ["clouds", "sunny", "vegetation"],
        "methods": ["ganspace", "sefa"],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_church_failure_diagnosis/structured_only_seed_2027",
        "seed": 2027
      }
    },
