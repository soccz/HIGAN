{
  "version": "control_v9_fixed_target_negatives",
  "locked_on": "2026-05-24",
  "purpose": "Stricter causal negative control: compare actual, shuffled, and inverted risk selection while estimating the matched edit target from the full candidate universe, so target magnitude is not affected by the selected mode.",
  "common": {
    "lod": 2.0,
    "batch": 4,
    "device": "cuda",
    "domain": "ffhq",
    "attrs": ["smile", "age", "pose", "gender", "eyeglasses"],
    "candidate_source": "experiments/out/control_direction_matched_full/metrics.json",
    "target_source": "universe"
  },
  "experiments": [
    {
      "key": "fixed_target_actual_seed_2027",
      "order": 1,
      "script": "experiments/control/run_risk_aware_controller.py",
      "claim_tested": "Fixed-target causal control: actual risk should outperform shuffled/inverted risk when target magnitude is estimated independently of selected mode.",
      "args": {
        "candidate-source": "experiments/out/control_direction_matched_full/metrics.json",
        "k-select": 8,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "n-probe": 32,
        "probe-alpha": 1.0,
        "n-calib": 32,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
