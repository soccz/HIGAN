        "k-select": 8,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "shuffled",
        "n-probe": 32,
        "probe-alpha": 1.0,
        "n-calib": 32,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
