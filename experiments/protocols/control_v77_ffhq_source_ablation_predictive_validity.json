  "version": "control_v77_ffhq_source_ablation_predictive_validity",
  "locked_on": "2026-05-29",
  "purpose": "Close the FFHQ candidate-source gap by testing GANSpace-only and SeFa-only prompt-ensemble predictive validity.",
  "experiments": [
    {
      "key": "ffhq_control_v77_ffhq_source_ablation_predictive_validity_ffhq_ganspace_only_seed_2147",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "Top-tier defense: rho predictive validity should remain auditable under ffhq_ganspace_only in ffhq; failures are kept as boundary evidence.",
      "args": {
        "domain": "ffhq",
        "attrs": [
          "smile",
          "age",
          "pose",
          "gender",
          "eyeglasses"
        ],
        "methods": [
          "ganspace"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "min-gain-quantile": 0.5,
        "gain-match-rel": 0.25,
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 2,
        "risk-estimator": "jvp",
        "prompt-style": "ensemble",
        "out": "experiments/out/control_cross_domain_risk_predictive_ffhq_prompt_ensemble_ganspace_only/ffhq_seed_2147",
