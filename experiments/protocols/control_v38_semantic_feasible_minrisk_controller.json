{
  "version": "control_v38_semantic_feasible_minrisk_controller",
  "locked_on": "2026-05-27",
  "purpose": "Test risk as a control variable under a predeclared semantic feasibility constraint, rather than as an unconstrained gain/risk ratio.",
  "experiments": [
    {
      "key": "church_feasible_low_risk_actual_seed_2047",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Semantic-feasible minimum-risk controller: after a fixed probe-gain feasibility filter, actual curvature/risk should choose lower-damage edits.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "selection-rule": "gain_feasible_low_risk",
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 128,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_feasible_risk_controller/church/actual_seed_2047",
