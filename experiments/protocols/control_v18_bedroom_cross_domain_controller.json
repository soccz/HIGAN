{
  "version": "control_v18_bedroom_cross_domain_controller",
  "locked_on": "2026-05-25",
  "purpose": "Cross-domain validation of the risk-aware control claim on HiGAN bedroom: rebuild the candidate universe and risk/gain measurements outside FFHQ, then test actual risk against baselines and shuffled/inverted risk controls.",
  "common": {
    "domain": "bedroom",
    "attrs": ["indoor_lighting", "wood", "view", "carpet", "cluttered_space", "glossy", "dirt", "scary"],
    "methods": ["ganspace", "sefa", "random"],
    "candidate_k_per_method": 6,
    "target_source": "universe",
    "lpips_net": "alex"
  },
  "experiments": [
    {
      "key": "bedroom_actual_seed_2027",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Bedroom cross-domain controller: actual curvature risk should improve matched-edit stability over gain-only/random/high-risk baselines.",
      "args": {
        "domain": "bedroom",
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_bedroom_cross_domain_true_lpips/actual_seed_2027",
        "seed": 2027
      }
