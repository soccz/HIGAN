{
  "version": "control_v25_church_structured_negative_controls",
  "locked_on": "2026-05-26",
  "purpose": "Negative controls for the church structured-only diagnosis. This tests whether the improved structured-only controller is driven by the actual curvature/risk signal rather than by candidate-source restriction alone.",
  "common": {
    "domain": "church",
    "attrs": ["clouds", "sunny", "vegetation"],
    "methods": ["ganspace", "sefa"],
    "target_source": "universe",
    "lpips_net": "alex"
  },
  "experiments": [
    {
      "key": "church_structured_shuffled_seed_2027",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Structured-only church negative control: shuffled risk should underperform actual risk if curvature carries control information inside the structured candidate universe.",
      "args": {
        "domain": "church",
        "attrs": ["clouds", "sunny", "vegetation"],
        "methods": ["ganspace", "sefa"],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 1.0,
        "risk-selection-mode": "shuffled",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_church_structured_negative_controls/shuffled_seed_2027",
