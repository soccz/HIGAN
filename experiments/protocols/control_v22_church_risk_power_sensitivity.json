{
  "version": "control_v22_church_risk_power_sensitivity",
  "locked_on": "2026-05-26",
  "purpose": "Sensitivity validation for the church StyleGAN2 cross-domain controller. The official controller uses risk_power=1.0; this protocol checks whether the control claim is robust around that value rather than dependent on a single tuned exponent.",
  "common": {
    "domain": "church",
    "attrs": ["clouds", "sunny", "vegetation"],
    "methods": ["ganspace", "sefa", "random"],
    "candidate_k_per_method": 6,
    "target_source": "universe",
    "lpips_net": "alex"
  },
  "experiments": [
    {
      "key": "church_risk_power_0p5_seed_2027",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_aware_controller.py",
      "claim_tested": "Church StyleGAN2 sensitivity check: weaker risk penalty should still be reported against all baselines.",
      "args": {
        "domain": "church",
        "attrs": ["clouds", "sunny", "vegetation"],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "k-select": 4,
        "min-gain-quantile": 0.5,
        "risk-power": 0.5,
        "risk-selection-mode": "actual",
        "target-source": "universe",
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "out": "experiments/out/control_church_risk_power_sensitivity/risk_power_0p5_seed_2027",
        "seed": 2027
