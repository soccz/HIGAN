{
  "version": "control_v63_random_universe_prompt_ensemble_predictive_validity",
  "locked_on": "2026-05-28",
  "purpose": "Test whether prompt-ensemble predictive validity survives adding unstructured random directions to the candidate universe.",
  "experiments": [
    {
      "key": "church_control_v63_random_universe_prompt_ensemble_predictive_validity_random_universe_seed_2122",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "The rho signal should remain directionally stable under random_universe stress in church; failures define boundary conditions rather than being filtered out.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa",
          "random"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "min-gain-quantile": 0.5,
        "gain-match-rel": 0.25,
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "risk-estimator": "jvp",
        "prompt-style": "ensemble",
        "out": "experiments/out/control_cross_domain_risk_predictive_prompt_ensemble_random_universe/church_seed_2122",
        "seed": 2122
      }
    },
