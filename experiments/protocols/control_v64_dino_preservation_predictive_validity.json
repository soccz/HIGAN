{
  "version": "control_v64_dino_preservation_predictive_validity",
  "locked_on": "2026-05-28",
  "purpose": "Test whether rho predicts damage in a non-language DINOv2 image feature space, not only CLIP-image consistency and LPIPS.",
  "experiments": [
    {
      "key": "church_control_v64_dino_preservation_predictive_validity_dino_preservation_seed_2127",
      "order": 1,
      "script": "experiments/control/run_cross_domain_risk_predictive.py",
      "claim_tested": "The rho signal should remain directionally stable under dino_preservation stress in church; failures define boundary conditions rather than being filtered out.",
      "args": {
        "domain": "church",
        "attrs": [
          "clouds",
          "sunny",
          "vegetation"
        ],
        "methods": [
          "ganspace",
          "sefa"
        ],
        "candidate-k": 6,
        "ganspace-samples": 2048,
        "min-gain-quantile": 0.5,
        "gain-match-rel": 0.25,
        "true-lpips": true,
        "lpips-net": "alex",
        "lpips-size": 256,
        "n-risk": 8,
        "n-probe": 16,
        "probe-alpha": 1.0,
        "n-calib": 16,
        "n-test": 64,
        "alpha-steps": 7,
        "max-alpha": 6,
        "target-quantile": 0.25,
        "batch": 4,
        "risk-estimator": "jvp",
        "prompt-style": "ensemble",
        "out": "experiments/out/control_cross_domain_risk_predictive_dino_preservation/church_seed_2127",
        "seed": 2127,
        "dino-preservation": true,
        "dino-local-files-only": true
